# Server
PORT=3001
NODE_ENV=development

# Frontend (CORS)
FRONTEND_URL=
FRONTEND_URLS=
ALLOW_VERCEL_PREVIEWS=false

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agarramais_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=sua_chave_secreta_super_segura_aqui_trocar_em_producao
JWT_EXPIRES_IN=7d

# Admin padrão
ADMIN_EMAIL=admin@agarramais.com
ADMIN_PASSWORD=Admin@123

# Evolution API (WhatsApp)
WHATSAPP_PROVIDER=evolution
EVOLUTION_URL=http://localhost:8080
EVOLUTION_INSTANCE_NAME=bot_alertas
EVOLUTION_API_KEY=
EVOLUTION_REQUEST_TIMEOUT_MS=15000
EVOLUTION_DEFAULT_DELAY_MS=1200
EVOLUTION_DEFAULT_PRESENCE=composing
EVOLUTION_SEND_TEXT_PATH_TEMPLATE=/message/sendText/{instance}

# Meta WhatsApp Cloud API (use WHATSAPP_PROVIDER=meta)
META_WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
META_WHATSAPP_API_VERSION=v22.0
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_REQUEST_TIMEOUT_MS=15000
META_WHATSAPP_FORCE_TEMPLATE=false
META_WHATSAPP_DEFAULT_TEMPLATE_NAME=hello_world
META_WHATSAPP_DEFAULT_TEMPLATE_LANGUAGE=en_US
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=
META_WHATSAPP_WEBHOOK_LOOKBACK_DAYS=90
META_WHATSAPP_WEBHOOK_LOOKBACK_LIMIT=2000

# Destino padrão dos alertas (formato internacional, ex: 5511999999999)
WHATSAPP_ALERT_DESTINO=

# Janela de deduplicação para evitar spam de alertas repetidos
ALERT_DEDUPLICATION_MINUTES=10

# Fila de alertas WhatsApp (BullMQ + Redis)
ALERT_QUEUE_ENABLED=false
ALERT_QUEUE_NAME=whatsapp-alertas
ALERT_QUEUE_CONCURRENCY=2
ALERT_QUEUE_ATTEMPTS=5
ALERT_QUEUE_BACKOFF_MS=5000
ALERT_QUEUE_REMOVE_ON_COMPLETE=1000
ALERT_QUEUE_REMOVE_ON_FAIL=2000

# Redis (usar REDIS_URL em produção, ex: Render/Upstash)
REDIS_URL=redis://localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false
